#cinsiyet değişkenini sayısal hale getiriyorum.

titanic$Sex_num <- as.numeric(titanic$Sex == "female")


#eksik veri  analizi yapıyorum.

colSums(is.na(titanic))
#eksik verileri ortalama ile dolduruyorum.
titanic$Age[is.na(titanic$Age)] <- mean(titanic$Age, na.rm = TRUE)

#Korelasyon analizi yapıyorum.

# Survived (0=Öldü, 1=Kurtuldu)

degiskenler <- titanic[, c("Survived", "Pclass", "Sex_num", "Age")]
cor(degiskenler)

barplot(table(titanic$Survived, titanic$Pclass),
        beside = TRUE,
        legend = c("Öldü", "Kurtuldu"),
        main = "Bilet Sınıfına Göre Hayatta Kalma",
        col = c("red", "green"))

  #Karar ağacı modeli ile hayatta kalmayı; sınıf, cinsiyet ve yaş değişkenleri üzerinden tahmin eden bir ağaç kurdum.

# rpart paketini yükle
library(rpart)

set.seed(123)
model_agac <- sample(2, nrow(titanic), replace = TRUE, prob = c(0.7, 0.3))

egitim_verisi <- titanic[model_agac == 1, ]
test_verisi <- titanic[model_agac == 2, ]
egitim_modeli <- rpart(Survived ~ Pclass + Sex + Age,
                     data = egitim_verisi,
                     method = "class")
tahminler <- predict(egitim_modeli, test_verisi, type = "class") # agac_modeli yerine egitim_modeli kullanıldı
tablo <- table(test_verisi$Survived, tahminler)
print(tablo)

#modelin doğruluk oranı

dogruluk <- sum(diag(tablo)) / sum(tablo)
print(paste("Modelin Doğruluk Oranı: %", round(dogruluk * 100, 2)))
